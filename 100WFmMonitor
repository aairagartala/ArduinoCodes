/*
 * FM Transmitter Monitor - Arduino Due
 * Web Server + Serial BitStream Parser + DHT11
 *
 * BitStream Layout (36 bytes, 0-indexed):
 *  [0]       - ON/OFF status (1=ON, 0=OFF)
 *  [1..4]    - Start string  (#,$,$,#)
 *  [5..9]    - Frequency digits (e.g. 1,0,1,6,0 => 101.60 MHz)
 *  [10..15]  - Audio level digits
 *  [16..17]  - Low Output Power fault flag (index 16: flag, 17: secondary)
 *  [18..20]  - Fwd Power digits  (e.g. 7,5,0 => 75.0 W)
 *  [21..23]  - Fault VSWR High   (index 21: flag)
 *  [22]      - Fault code tens digit  (7=all fault, 1=low+fault)
 *  [23]      - Fault code units digit (3=all fault, 6=low+fault)
 *  [24..29]  - Refl Power digits (e.g. 5,0,0,0,0,0 => 5.0 W)
 *  [30..31]  - Set Power digits  (e.g. 8,5 => 85 W)
 *  [32..35]  - End string ($,#,#,$)
 *
 * Fault Logic:
 *  Cond1: buf[22]='7' AND buf[23]='3' → ALL 4 faults active
 *  Cond2: buf[22]='1' AND buf[23]='6' → fPowerLow + fFault active
 *  Cond3: (no cond1/2) fwdPower > 100 → fPowerHigh only
 *  Cond4: (no cond1/2) fwdPower < 40  → fPowerLow only
 *
 * Notes for Arduino Due:
 *  - 3.3V I/O — DO NOT connect 5V signals directly
 *  - Uses Ethernet shield (W5100/W5500) on SPI pins 50-53
 *  - Serial1 used for Tx data stream (RX=pin19, TX=pin18)
 *  - Serial2 : RX=pin17, TX=pin16  (spare)
 *  - Serial3 : RX=pin15, TX=pin14  (spare)
 *  - 96KB SRAM — HTML page kept minimal / served in flushed chunks
 *  - No PROGMEM on Due (SAM3X has unified address space)
 *  - Watchdog disabled by default on Due; re-enable if needed
 *
 * ADDED: DHT11 on pin 48
 *  - Read on same 2000ms cycle as bitstream
 *  - NaN on read error → displays "--" on webpage
 */

#include <SPI.h>
#include <Ethernet.h>
// ADDED: DHT library
#include <DHT.h>

// ── Network config ────────────────────────────────────────────────────────────
byte mac[]     = { 0xDE, 0xAD, 0xBE, 0xEF, 0xFE, 0xED };
IPAddress ip(192, 168, 1, 177);
EthernetServer server(80);

// ── BitStream config ──────────────────────────────────────────────────────────
#define STREAM_LEN   36
#define START_CHAR_0 '#'
#define START_CHAR_1 '$'
#define END_CHAR_0   '$'
#define END_CHAR_3   '$'

char   streamBuf[STREAM_LEN];
bool   streamReady = false;

// ADDED: DHT11 config
#define DHT_PIN  50
#define DHT_TYPE DHT11
DHT dht(DHT_PIN, DHT_TYPE);

// ── Parsed Tx parameters ──────────────────────────────────────────────────────
struct TxData {
  bool    txOn;
  float   freqMHz;
  float   audioLevel;
  float   fwdPowerW;
  float   reflPowerW;
  float   setPowerW;
  bool    faultPowerHigh;
  bool    faultPowerLow;
  bool    faultGeneral;
  bool    faultVSWR;
  // ADDED: DHT11 fields
  float   tempC;        // NaN if read error
  float   humidity;     // NaN if read error
  bool    dhtOk;        // false if last read failed
  int adcRaw;
  bool    valid;
} tx;

// ── TX control pins ───────────────────────────────────────────────────────────
#define PIN_TX_ON_CMD   7
#define PIN_TX_OFF_CMD  8

// ── Timing ────────────────────────────────────────────────────────────────────
unsigned long lastParse  = 0;
const    long PARSE_INT  = 500;

unsigned long lastParsea  = 0;

char c;

static char    inBuf[STREAM_LEN * 2];
static uint8_t idx = 0;

int inbf[56];
int i = 0;

// =============================================================================
// SETUP  — CHANGED: added dht.begin()
// =============================================================================
void setup() {
  Serial.begin(115200);
  Serial1.begin(9600);

  pinMode(PIN_TX_ON_CMD,  OUTPUT);
  pinMode(PIN_TX_OFF_CMD, OUTPUT);
  digitalWrite(PIN_TX_ON_CMD,  LOW);
  digitalWrite(PIN_TX_OFF_CMD, LOW);

  // ADDED: init DHT11
  dht.begin();

  Ethernet.begin(mac, ip);
  delay(1000);

  server.begin();
  Serial.print(F("Server at "));
  Serial.println(Ethernet.localIP());

  memset(streamBuf, '0', STREAM_LEN);
  memset(&tx, 0, sizeof(tx));

  // ADDED: init DHT fields to safe defaults
  tx.tempC    = NAN;
  tx.humidity = NAN;
  tx.dhtOk    = false;

  tx.adcRaw = 0;
}

// =============================================================================
// LOOP  — unchanged
// =============================================================================
void loop() {
  if (millis() - lastParsea > 2000) {
    Serial1.write('R');
    readSerial();
    parseBitStream();
    // ADDED: read DHT on same cycle
    readDHT();

    readADC();

    lastParsea = millis();
  }

  handleClient();
}

// =============================================================================
// SERIAL READER  — unchanged
// =============================================================================
void readSerial() {
  while (Serial1.available()) {
    c = Serial1.read();
    if (c=='$' || c=='#' || c=='1' || c=='2' || c=='3' || c=='4' ||
        c=='5' || c=='6' || c=='7' || c=='8' || c=='9' || c=='0') {
      inBuf[idx++] = c;
    }
  }

  if (idx >= STREAM_LEN * 2) idx = 0;

  if (idx >= STREAM_LEN) {
    int end = idx - 1;
    if (inBuf[end] == '$') {
      int start = end - STREAM_LEN + 1;
      if (start >= 0 &&
          inBuf[start + 1] == '#' &&
          inBuf[start + 2] == '$' &&
          inBuf[start + 3] == '$' &&
          inBuf[start + 4] == '#') {
        memcpy(streamBuf, &inBuf[start], STREAM_LEN);
        streamReady = true;
        idx = 0;
        memset(inBuf, 0, sizeof(inBuf));
      }
    }
  }
}

// =============================================================================
// ADDED: DHT11 READER
// Reads temp and humidity; sets dhtOk=false and NaN values on error
// DHT11 needs ~1s between reads — safe inside the 2000ms cycle
// =============================================================================
void readDHT() {
  float h = dht.readHumidity();
  float t = dht.readTemperature();   // Celsius

  if (isnan(h) || isnan(t)) {
    tx.dhtOk    = false;
    tx.tempC    = NAN;
    tx.humidity = NAN;
    Serial.println(F("[DHT] Read error"));
  } else {
    tx.dhtOk    = true;
    tx.tempC    = t;
    tx.humidity = h;
    Serial.print(F("[DHT] Temp="));   Serial.print(t, 1);
    Serial.print(F("C  Humid="));     Serial.print(h, 1);
    Serial.println(F("%"));
  }
}

void readADC() {
  tx.adcRaw = analogRead(A9) *0.54;
  Serial.print(F("[ADC] A9 raw="));
  Serial.println(tx.adcRaw);
}


// =============================================================================
// PARSER  — unchanged
// =============================================================================
void parseBitStream() {
  auto digits = [](char* buf, int start, int len) -> int {
    int val = 0;
    for (int i = start; i < start + len; i++) {
      char c = buf[i];
      if (c >= '0' && c <= '9') val = val * 10 + (c - '0');
    }
    return val;
  };

  tx.txOn = (streamBuf[0] == '1');

  int freqRaw = digits(streamBuf, 5, 5);
  tx.freqMHz  = freqRaw / 100.0f;

  int audioRaw = digits(streamBuf, 10, 6);
  tx.audioLevel = audioRaw / 10.0f;

  int fwdRaw = digits(streamBuf, 18, 3);
  tx.fwdPowerW = fwdRaw / 10.0f;

  int reflRaw = digits(streamBuf, 24, 2);
  tx.reflPowerW = reflRaw / 10.0f;

  tx.setPowerW = (float)digits(streamBuf, 30, 2);

  char f1 = streamBuf[21];
  char f2 = streamBuf[22];

  if (f1 == '7' && f2 == '3') {
    tx.faultPowerHigh = true;
    tx.faultPowerLow  = true;
    tx.faultGeneral   = true;
    tx.faultVSWR      = true;
  }
  else if (f1 == '1' && f2 == '6') {
    tx.faultPowerHigh = false;
    tx.faultPowerLow  = true;
    tx.faultGeneral   = true;
    tx.faultVSWR      = false;
  }

  else if (f1 == '6' && f2 == '5') {
    tx.faultPowerHigh = false;
    tx.faultPowerLow  = true;
    tx.faultGeneral   = true;
    tx.faultVSWR      = true;
  }

  else if (tx.fwdPowerW > 100.0f) {
    tx.faultPowerHigh = true;
    tx.faultPowerLow  = false;
    tx.faultGeneral   = false;
    tx.faultVSWR      = false;
  }
  else if (tx.fwdPowerW < 40.0f) {

    if(tx.txOn==1)
    {
    tx.faultPowerHigh = false;
    tx.faultPowerLow  = true;
    tx.faultGeneral   = false;
    tx.faultVSWR      = false;
    }
  
  }
  else {
    tx.faultPowerHigh = false;
    tx.faultPowerLow  = false;
    tx.faultGeneral   = false;
    tx.faultVSWR      = false;
  }

  tx.valid = true;

  Serial.print(F("Tx:"));    Serial.print(tx.txOn);
  Serial.print(F(" Freq:")); Serial.print(tx.freqMHz);
  Serial.print(F(" Fwd:"));  Serial.print(tx.fwdPowerW);
  Serial.print(F(" Refl:")); Serial.print(tx.reflPowerW);
  Serial.print(F(" f1="));   Serial.print(f1);
  Serial.print(F(" f2="));   Serial.print(f2);
  Serial.print(F(" PwrHi=")); Serial.print(tx.faultPowerHigh);
  Serial.print(F(" PwrLo=")); Serial.print(tx.faultPowerLow);
  Serial.print(F(" Fault="));  Serial.print(tx.faultGeneral);
  Serial.print(F(" VSWR="));   Serial.println(tx.faultVSWR);

   
}

// =============================================================================
// BUILD JSON  — CHANGED: added temp and humid fields
// =============================================================================
void sendJSON(EthernetClient &client) {
  client.print(F("HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nConnection: close\r\n\r\n"));
  client.print(F("{"));
  client.print(F("\"on\":")); client.print(tx.txOn ? 1 : 0); client.print(F(","));
  client.print(F("\"freq\":")); client.print(tx.freqMHz, 2); client.print(F(","));
  client.print(F("\"fwd\":")); client.print(tx.fwdPowerW, 1); client.print(F(","));
  client.print(F("\"refl\":")); client.print(tx.reflPowerW, 1); client.print(F(","));
  client.print(F("\"set\":")); client.print(tx.setPowerW, 0); client.print(F(","));
  client.print(F("\"audio\":")); client.print(tx.audioLevel, 1); client.print(F(","));
  client.print(F("\"fVSWR\":")); client.print(tx.faultVSWR ? 1 : 0); client.print(F(","));
  client.print(F("\"fHigh\":")); client.print(tx.faultPowerHigh ? 1 : 0); client.print(F(","));
  client.print(F("\"fLow\":")); client.print(tx.faultPowerLow ? 1 : 0); client.print(F(","));
  client.print(F("\"fFault\":")); client.print(tx.faultGeneral ? 1 : 0); client.print(F(","));
  // ADDED: DHT fields — send -999 as sentinel when read failed (NaN is not valid JSON)
  if (tx.dhtOk) {
    client.print(F("\"temp\":")); client.print(tx.tempC, 1); client.print(F(","));
    client.print(F("\"humid\":")); client.print(tx.humidity, 1);client.print(F(","));
  } else {
    client.print(F("\"temp\":-999,"));
    client.print(F("\"humid\":-999,"));
  }

   client.print(F("\"adc\":")); client.print(tx.adcRaw);

  client.print(F("}"));
}

// =============================================================================
// HTTP CLIENT HANDLER  — unchanged
// =============================================================================
void handleClient() {
  EthernetClient client = server.available();
  if (!client) return;

  char reqLine[64];
  uint8_t ri = 0;
  unsigned long timeout = millis() + 1500;

  while (client.connected() && millis() < timeout) {
    if (client.available()) {
      char c = client.read();
      if (c == '\n') break;
      if (ri < 63) reqLine[ri++] = c;
    }
  }
  reqLine[ri] = '\0';

  bool blankLine = false;
  char prev = 0;
  timeout = millis() + 1500;
  while (client.connected() && !blankLine && millis() < timeout) {
    if (client.available()) {
      char c = client.read();
      if (c == '\n' && prev == '\r') blankLine = true;
      prev = c;
    }
  }

  if (strstr(reqLine, "GET /data")) {
    sendJSON(client);
  } else if (strstr(reqLine, "GET /txon")) {
    Serial1.write('A');
    client.print(F("HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nConnection: close\r\n\r\nOK"));
  } else if (strstr(reqLine, "GET /txoff")) {
    Serial1.write('B');
    client.print(F("HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nConnection: close\r\n\r\nOK"));
  } else {
    sendHTMLPage(client);
  }

  delay(1);
  client.stop();
}

